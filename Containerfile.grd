# fedora-desktop — GRD lineage (Containerfile.grd)
# ============================================================================
# The MODERN/durable camp: GNOME 50 (Wayland) + GNOME Remote Desktop (GRD) on a
# systemd-PID-1 base — the fedora-dev harness (claudebox + daily self-update +
# nested rootless podman) re-expressed as systemd units. Sibling to the xrdp
# lineage (Containerfile); they share the harness, the app set, the policy, and
# the ratified Principle-2(c) — only the ACCESS layer + the INIT contract differ.
#
# 3-AXIS ACCESS, all converging on ONE GRD session:
#   RDP  — GRD native (FreeRDP, :3389, TLS), tailnet-only
#   VNC  — GRD native (grdctl vnc, libvncserver, :5900), tailnet-only
#   web  — per WEB_GATEWAY (the SOLE public desktop door, TLS :8443):
#            guacamole — guacd -> GRD's loopback RDP -> HTML5 (RDP-grade; the
#                        guacamole.war is the lone class-(c) artifact, GPG-verified)
#            novnc     — noVNC + websockify -> GRD's loopback VNC (ALL class-(a))
#          Default guacamole; identical selector to the xrdp + krdp lineages.
#
# HEADLESS (binding prerequisite — see CLAUDE.md): runs with NO monitor/GPU/seat;
# the session is mutter --headless rendered by software GL (llvmpipe).
#
# MINIMALISM: minimal LEAF packages (install_weak_deps=False); a real gnome-shell
# desktop irreducibly carries webkitgtk6.0 + webkit2gtk4.1 (~182 MiB, the
# captive-portal helper + evolution-data-server) + gnome-control-center — these
# are HARD requires, disclosed in CLAUDE.md, NOT bloat-by-choice.
#
# CONTROL-PLANE / STOP-AND-SURFACE: systemd-PID-1 requires the HOST to grant
# cgroup-v2 delegation + writable /sys/fs/cgroup. Deploy only on a delegating
# host (Fedora CoreOS-class, or `podman --systemd=always` with delegation) via
# run.sh.grd (the SOLE sanctioned grd deploy contract; no Quadlet yet) — never the
# xrdp run.sh.
ARG FEDORA_VERSION=44
FROM registry.fedoraproject.org/fedora:${FEDORA_VERSION}

# Pinned Apache Guacamole .war (the lone class-(c) artifact) + its release-signing
# key fingerprint — GPG-verified before use (PRINCIPLE 2c). Shared with the xrdp
# lineage's guacamole gateway.
ARG GUAC_VERSION=1.6.0
ARG GUAC_GPG_FP=F467E54ACC52F1D2778826865B2977AEE5E4518F
ARG WEB_GATEWAY=guacamole

ENV LANG=en_US.UTF-8

COPY install-grd.sh /tmp/install-grd.sh
RUN GUAC_VERSION="${GUAC_VERSION}" GUAC_GPG_FP="${GUAC_GPG_FP}" \
    WEB_GATEWAY="${WEB_GATEWAY}" \
    bash /tmp/install-grd.sh && rm /tmp/install-grd.sh

COPY --chmod=755 entrypoint-grd.sh /usr/local/bin/entrypoint-grd.sh

# Shared box-assembly seed (identical to the xrdp lineage) — the claudebox
# machinery + policy + helper scripts. Under systemd-PID-1 the claudebox runs as
# a `systemd --user` service for core (loginctl enable-linger), which is the
# idiomatic home for nested rootless podman.
COPY distrobox.ini claudebox-init.sh box-rebuild.sh claudebox-daily.sh \
     claudebox-assemble.sh README.md CLAUDE.md /usr/local/share/fedora-dev/
COPY policy/ /usr/local/share/fedora-dev/policy/
COPY --chmod=755 bin/claude bin/claudebox-rebuild /usr/local/bin/
COPY bin/ /usr/local/share/fedora-dev/bin/
COPY policy/hooks/ /usr/local/share/fedora-dev/policy/hooks/

VOLUME ["/home/core", "/var/lib/tailscale", "/var/lib/guac-cert"]

# EXPOSE is metadata only (run.sh.grd / the Quadlet own the publish set). ONLY
# 8443 (Guacamole web), 4444->22 (ssh), mosh are public; 3389 (GRD RDP) + 5900
# (GRD VNC) are TAILNET-ONLY.
EXPOSE 22 8443 3389 5900 61001-62000/udp

# systemd is PID 1 — the GRD requirement. STOPSIGNAL per the systemd container
# convention. entrypoint-grd.sh runs as a first-boot oneshot unit (installed by
# install-grd.sh), NOT as PID 1.
STOPSIGNAL SIGRTMIN+3
ENTRYPOINT ["/sbin/init"]
