# fedora-desktop .live-gate — the workload-shipped, self-describing live-gate spec.
# ============================================================================
# PARSED — NEVER SOURCED — by the host's model-C live-gate (live-gate-run.sh's lg_load reads this
# file line by line and assigns each KEY=VALUE with `printf -v`; it NEVER `.`/`source`s it, since
# this file travels in the UNTRUSTED PR head). Declare INERT KEY=VALUE pairs ONLY: one assignment
# per line, schema keys only, and NO cross-variable references ($OTHER) — inline each value. Single-
# quote any HEALTH/PROBE command (its $()/`` run later INSIDE the fenced candidate, never on the host).
# Shipping the spec IN the repo (vs the host's ~/.config/live-gate/<wl>.env fallback) lets it AUTO-
# TRACK the run-contract on the same PR that changes it — the gate validates the candidate exactly
# as run.sh / run.sh.grd would run it, MINUS the public publish + the real secrets.
#
# fedora-desktop ships TWO LINEAGES in one repo (see CLAUDE.md "THE TWO LINEAGES"). They share
# the harness, the app set, and the SOLE public web gate (Apache Guacamole on :8443), differing
# only in the BUILD (Containerfile) + the INIT contract (fence) + the native servers:
#   * xrdp (Containerfile)     — supervised-bash PID 1; XFCE-on-X11 + xrdp.   The production lineage.
#   * grd  (Containerfile.grd) — systemd-PID-1; GNOME-Wayland + GRD.          STOP-AND-SURFACE host ask.
# Because they are separate BUILDS, this is a MULTI-TARGET spec: the gate builds + live-runs +
# probes EACH target independently. (This supersedes the single-env + baked-lineage-marker preset
# the host shipped as a fallback; here the .live-gate declares both targets explicitly.)
#
# ---- SCHEMA (multi-target, PARSED contract — not sourced; consumed by the model-C gate) -------
#   LIVE_GATE_TARGETS  space-separated list of target names the gate iterates. For each name <T>,
#                      the gate reads these SUFFIX-form CFG_<T> vars via indirect expansion — the
#                      host consumer uses `pt(){ local v="${1}_${2}"; printf '%s' "${!v:-$3}"; }`,
#                      i.e. `pt CFILE grd` -> $CFILE_grd. (Keys are KEY_<T>, NOT <T>_KEY.)
#     CFILE_<T>        Containerfile the candidate is built from (build-candidate.sh's 4th arg)
#     FENCE_<T>        podman run fence = that lineage's run.sh contract MINUS the public -p and
#                      MINUS the real secrets/volumes (caps/devices/security flags only). The gate
#                      probes :8443 on the candidate's OWN loopback via `podman exec`, so NOTHING is
#                      published to the host — never add a `-p` here.
#     HEALTH_<T>       the --health-cmd (OCI images drop the Containerfile HEALTHCHECK, so the gate
#                      re-supplies it). MIRRORS run.sh / run.sh.grd's --health-cmd verbatim.
#     PROBE_<T>        the access-path "does it actually serve" assertion, run INSIDE the candidate
#                      via `podman exec` (candidate's own loopback). Exit 0 = serves.
#     SECRET_MOUNT_<T> in-container path the gate bind-mounts a 0600 scratch secrets file at (ro).
#     SECRET_ENV_<T>   KEY=VALUE lines for that scratch file — DISPOSABLE test values, NEVER the
#                      real secrets, NEVER baked into any layer (Principle 5). The entrypoint's
#                      fail-fast required pair (RDP_PW + GUAC_PW) so the candidate provisions + serves.
#   Gate-imposed (NOT run-contract) resource caps + first-boot budget, shared by all targets — a full
#   desktop (JVM/Tomcat + MariaDB + GNOME/XFCE) needs more headroom + a longer first-boot window
#   than a bare-sshd box: CAND_MEMORY CAND_PIDS CAND_HEALTH_START CAND_HEALTH_TRIES CAND_HEALTH_SLEEP.
# ============================================================================

LIVE_GATE_TARGETS="xrdp grd"

# Shared across BOTH lineages BY VALUE — the gate PARSES this contract (no cross-variable refs), so
# each target inlines its own literal below. They front the SAME Guacamole web gate on :8443 over the
# SAME loopback RDP :3389, and BOTH consume /etc/fedora-desktop/secrets.env (xrdp sources it, grd's
# firstboot oneshot EnvironmentFile-reads it). HEALTH/PROBE are SINGLE-QUOTED so the inner $(...) /
# "%{http_code}" reach --health-cmd / podman-exec LITERALLY and run only inside the fenced candidate.

# ---- target: xrdp (Containerfile) — supervised-bash PID 1; XFCE-on-X11 + xrdp -----------------
# FENCE = run.sh's podman-run flags MINUS `-p ${WEB_PORT}:8443` and MINUS the bind-mounted real
# secrets / persisted volumes (caps + devices + label-disable only). PROBE: the DEEP equivalence
# probe (bin/gate-deep-probe.sh, shipped via `COPY bin/`) — beyond web/RDP/DB it asserts the desktop
# SESSION is rendering (xrdp: live Xorg :10) + RDP-server config (bpp=24, Xorg backend, resume) +
# the Guacamole auth chain (jdbc/totp extensions + the core DB identity). HEALTH still gates basics.
# HEALTH mirrors run.sh's --health-cmd. Scratch RDP_PW/GUAC_PW via the bind-mounted secrets.env.
CFILE_xrdp='Containerfile'
FENCE_xrdp='--shm-size=1g --cap-add NET_ADMIN --cap-add SYS_ADMIN --device /dev/net/tun --device /dev/fuse --security-opt label=disable'
HEALTH_xrdp='[ "$(curl -sk -o /dev/null -w "%{http_code}" https://127.0.0.1:8443/guacamole/)" = 200 ] && exec 3<>/dev/tcp/127.0.0.1/3389 && mariadb-admin --socket=/var/lib/mysql/mysql.sock ping'
PROBE_xrdp='bash /usr/local/share/fedora-dev/bin/gate-deep-probe.sh xrdp'
SECRET_MOUNT_xrdp='/etc/fedora-desktop/secrets.env'
SECRET_ENV_xrdp='RDP_PW=gate-scratch-rdp-not-a-real-secret
GUAC_PW=gate-scratch-guac-not-a-real-secret'

# ---- target: grd (Containerfile.grd) — systemd-PID-1; GNOME-Wayland + GRD ----------------------
# FENCE = run.sh.grd's flags MINUS `-p ${WEB_PORT}:8443` and MINUS real secrets/volumes, PLUS the
# systemd-PID-1 contract (--systemd=always --cgroupns=host -v /sys/fs/cgroup:rw --device /dev/fuse)
# so a systemd-PID-1 candidate can ACTUALLY BOOT for the gate. SAME HEALTH as xrdp; PROBE is the SAME
# deep equivalence probe (grd branch: GDM headless session active + compositor running + GRD is the
# :3389 listener + mutter paint signature). Scratch RDP_PW/GUAC_PW via the
# bind-mounted secrets.env — NEVER baked (grd's firstboot oneshot EnvironmentFile-reads it).
CFILE_grd='Containerfile.grd'
FENCE_grd='--systemd=always --cgroupns=host -v /sys/fs/cgroup:/sys/fs/cgroup:rw --shm-size=1g --cap-add NET_ADMIN --cap-add SYS_ADMIN --device /dev/net/tun --device /dev/fuse --security-opt label=disable'
HEALTH_grd='[ "$(curl -sk -o /dev/null -w "%{http_code}" https://127.0.0.1:8443/guacamole/)" = 200 ] && exec 3<>/dev/tcp/127.0.0.1/3389 && mariadb-admin --socket=/var/lib/mysql/mysql.sock ping'
PROBE_grd='bash /usr/local/share/fedora-dev/bin/gate-deep-probe.sh grd'
SECRET_MOUNT_grd='/etc/fedora-desktop/secrets.env'
SECRET_ENV_grd='RDP_PW=gate-scratch-rdp-not-a-real-secret
GUAC_PW=gate-scratch-guac-not-a-real-secret'

# ---- gate-imposed resource caps + first-boot health budget (shared by both targets) ------------
CAND_MEMORY='4g'
CAND_PIDS='2048'
CAND_HEALTH_START='90s'
CAND_HEALTH_TRIES='40'
CAND_HEALTH_SLEEP='6'
